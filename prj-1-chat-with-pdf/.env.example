# Copy this file to .env and fill in your values.
#   cp .env.example .env

# Required - your OpenAI API key (used for both embeddings and chat).
OPENAI_API_KEY=sk-your-key-here

# Optional - models. Defaults match the phase-4-rag scripts.
MODEL_CHAT=gpt-5-nano
MODEL_EMBED=text-embedding-3-small

# Optional - chunk sizing for indexing. Larger chunks preserve code blocks and
# multi-paragraph answers better. 1500/300 works well for technical PDFs.
# Note: applies only to NEWLY uploaded PDFs; existing ones keep their old size.
CHUNK_SIZE=1500
CHUNK_OVERLAP=300

# Optional - how many chunks to retrieve from Qdrant per query. Higher = more
# chance the full answer/code is present; ~8 is a good balance for code PDFs.
RETRIEVAL_K=8

# Optional - how many prior messages get replayed to the LLM as context.
# Higher = better continuity in multi-turn chats, but every turn also re-injects
# the retrieved chunks, so total tokens per turn grow with this value.
# 6 is a good default for single-user dev. Set to 0 to disable history entirely.
HISTORY_WINDOW=6
